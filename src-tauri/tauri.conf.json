{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipLens",
  "version": "0.1.0",
  "identifier": "com.spdshka.cliplens",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipLens",
        "width": 820,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "focus": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
